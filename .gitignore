# OAuth tokens — never commit
scripts/gmail_credentials/*-client.json
scripts/gmail_credentials/*-token.json

# Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/

# OS
.DS_Store

# Obsidian local vault settings and workspace state
.obsidian/

# Podcast build output (generated from wiki content)
podcast/out/

# Private personal notes — track structure, not content
personal/**
!personal/**/
!personal/**/.gitkeep

# Personal Wiki Agent runtime artifacts
personal-wiki-agent/logs/
personal-wiki-agent/app/config.local.toml
